# ============================================
# FideliQR FULL V1 - Variables de Entorno
# ============================================
# Copia este archivo como .env y completa los valores

# ============================================
# BASE DE DATOS (REQUERIDO)
# ============================================
# Obtener desde: https://console.neon.tech
DATABASE_URL="postgresql://usuario:contraseña@ep-xxx.us-west-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://usuario:contraseña@ep-xxx.us-west-2.aws.neon.tech/neondb?sslmode=require"

# ============================================
# AUTENTICACIÓN (REQUERIDO)
# ============================================
# Generar con: openssl rand -base64 32
JWT_SECRET="tu-jwt-secret-seguro-cambiar-en-produccion"

# ============================================
# EMAIL - Gmail SMTP (REQUERIDO para notificaciones)
# ============================================
# Para Gmail necesitas una "Contraseña de aplicación"
# 1. Ve a https://myaccount.google.com/security
# 2. Activa "Verificación en 2 pasos"
# 3. Ve a "Contraseñas de aplicaciones"
# 4. Genera una nueva contraseña para "Correo"
# 5. Usa esa contraseña aquí (no tu contraseña normal de Gmail)

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-contraseña-de-aplicacion-de-16-caracteres"
SMTP_FROM="FideliQR <tu-email@gmail.com>"

# ============================================
# CRON JOBS (REQUERIDO para automatización)
# ============================================
# Secreto para autorizar las llamadas de cron-job.org
# Genera uno único y seguro
CRON_SECRET="tu-cron-secret-unico-y-seguro"

# ============================================
# APP (Opcional)
# ============================================
NEXT_PUBLIC_APP_URL="https://tu-app.vercel.app"
NODE_ENV="production"

# ============================================
# NOTAS ADICIONALES
# ============================================
# Las configuraciones de WhatsApp (CallMeBot) y Telegram
# se guardan en la base de datos desde el panel admin:
# 
# WhatsApp (CallMeBot):
#   - callmebotApikey: Tu API key de CallMeBot
#   - callmebotPhone: Número de teléfono con código de país
#
# Telegram:
#   - telegramBotToken: Token del bot de Telegram
#   - telegramChatId: ID del chat/grupo
#
# CallMeBot: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Telegram Bot: Habla con @BotFather en Telegram
